# PostgreSQL（compose の postgres サービスと api の接続先）
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_PORT=5432

# ホストからアクセスするポート
NGINX_PORT=80
API_PORT=8000
WEB_PORT=5173

# ブラウザ用（nginx 経由の同一オリジン。相対パス /api を推奨）
VITE_API_URL=/api

# バックエンドの CORS（カンマ区切り。:5173 直アクセス時用に localhost も含める）
CORS_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1:5173

# nginx 経由で /api/docs を開くときの OpenAPI ベースパス
ROOT_PATH=/api

# Docker Desktop（Mac）などでファイル監視が不安定なとき 1
VITE_USE_POLLING=0
