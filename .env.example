# PostgreSQL（compose の postgres サービスと api の接続先）
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_PORT=5432

# ホストからアクセスするポート
API_PORT=8000
WEB_PORT=5173

# ブラウザ用（フロントが fetch する API の URL。ホストのブラウザからは localhost）
VITE_API_URL=http://localhost:8000

# バックエンドの CORS（カンマ区切り）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Docker Desktop（Mac）などでファイル監視が不安定なとき 1
VITE_USE_POLLING=0
